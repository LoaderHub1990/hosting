// src/lib/fileManager.js
// -----------------------------------------------------------------------
// Every function resolves paths against a single server's own folder and
// then verifies the result is still INSIDE that folder before touching
// disk. This is what stops "../../../../etc/passwd" style path traversal.
// Never bypass safeResolve() — it's the one thing standing between a
// user's file box and the rest of the VPS.
// -----------------------------------------------------------------------
import { promises as fs } from "node:fs";
import path from "node:path";
import { exec } from "node:child_process";
import { promisify } from "node:util";
import { config } from "../config.js";

const execAsync = promisify(exec);

export function serverDir(serverId) {
  return path.join(config.serversDir, serverId);
}

export function safeResolve(serverId, relPath = "") {
  const base = serverDir(serverId);
  const target = path.resolve(base, relPath || ".");
  if (target !== base && !target.startsWith(base + path.sep)) {
    throw new Error("Path traversal blocked");
  }
  return target;
}

export async function ensureServerDir(serverId) {
  await fs.mkdir(serverDir(serverId), { recursive: true });
}

export async function listDir(serverId, relPath = "") {
  const dir = safeResolve(serverId, relPath);
  const entries = await fs.readdir(dir, { withFileTypes: true });
  const results = [];
  for (const entry of entries) {
    if (entry.name.startsWith(".")) continue; // hide dotfiles from the UI
    const full = path.join(dir, entry.name);
    const stat = await fs.stat(full);
    results.push({
      name: entry.name,
      type: entry.isDirectory() ? "dir" : "file",
      size: entry.isDirectory() ? null : formatSize(stat.size),
    });
  }
  // dirs first, then alphabetical
  results.sort((a, b) => (a.type === b.type ? a.name.localeCompare(b.name) : a.type === "dir" ? -1 : 1));
  return results;
}

export async function readFile(serverId, relPath) {
  const file = safeResolve(serverId, relPath);
  return fs.readFile(file, "utf-8");
}

export async function writeFile(serverId, relPath, content) {
  const file = safeResolve(serverId, relPath);
  await fs.mkdir(path.dirname(file), { recursive: true });
  await fs.writeFile(file, content ?? "");
}

/**
 * Writes a file uploaded via the drag-and-drop / file-picker uploader.
 * `content` is a Buffer (raw bytes) — used instead of writeFile() so binary
 * files (images, zips, etc.) survive the round trip intact.
 */
export async function writeUploadedFile(serverId, relPath, buffer) {
  const file = safeResolve(serverId, relPath);
  await fs.mkdir(path.dirname(file), { recursive: true });
  await fs.writeFile(file, buffer);
}

export async function deleteEntry(serverId, relPath) {
  const target = safeResolve(serverId, relPath);
  await fs.rm(target, { recursive: true, force: true });
}

export async function mkdir(serverId, relPath) {
  const dir = safeResolve(serverId, relPath);
  await fs.mkdir(dir, { recursive: true });
}

export async function readPackageJson(serverId) {
  try {
    const raw = await readFile(serverId, "package.json");
    return JSON.parse(raw);
  } catch {
    return { name: serverId, version: "1.0.0", dependencies: {} };
  }
}

export async function writePackageJson(serverId, pkg) {
  await writeFile(serverId, "package.json", JSON.stringify(pkg, null, 2));
}

function formatSize(bytes) {
  if (bytes < 1024) return `${bytes} B`;
  if (bytes < 1024 ** 2) return `${(bytes / 1024).toFixed(1)} KB`;
  return `${(bytes / 1024 ** 2).toFixed(1)} MB`;
}

/**
 * Total size (in bytes) of a server's whole folder, including node_modules.
 * Tries the fast `du` (Linux/macOS) first, falls back to a plain recursive
 * walk in JS so this still works on Windows during local dev.
 */
export async function diskUsage(serverId) {
  const dir = serverDir(serverId);
  try {
    const { stdout } = await execAsync(`du -sb "${dir}"`);
    const bytes = parseInt(stdout.split("\t")[0], 10);
    if (!Number.isNaN(bytes)) return bytes;
  } catch {
    // du not available (e.g. Windows) — fall through to the JS walk below
  }
  return walkSize(dir);
}

async function walkSize(dir) {
  let total = 0;
  let entries;
  try {
    entries = await fs.readdir(dir, { withFileTypes: true });
  } catch {
    return 0;
  }
  for (const entry of entries) {
    const full = path.join(dir, entry.name);
    if (entry.isDirectory()) {
      total += await walkSize(full);
    } else {
      try {
        total += (await fs.stat(full)).size;
      } catch {
        /* file vanished mid-walk, ignore */
      }
    }
  }
  return total;
}
